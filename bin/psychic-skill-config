#!/usr/bin/env bash
# psychic-skill-config — read/write ~/.psychic-skill/config.yaml
#
# Usage:
#   psychic-skill-config get <key>          — read a config value
#   psychic-skill-config set <key> <value>  — write a config value
#   psychic-skill-config list               — show all config
#
# Env overrides (for testing):
#   PSYCHIC_SKILL_STATE_DIR  — override ~/.psychic-skill state directory
set -euo pipefail

STATE_DIR="${PSYCHIC_SKILL_STATE_DIR:-$HOME/.psychic-skill}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: psychic-skill-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: psychic-skill-config set <key> <value>}"
    VALUE="${3:?Usage: psychic-skill-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i '' "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: psychic-skill-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
