#!/usr/bin/env bash
# psychic-skill-update-check — periodic version check for all skills.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>       — marker found from recent upgrade
#   UPGRADE_AVAILABLE <old> <new>   — some installed copy is behind remote
#   (nothing)                       — up to date, snoozed, disabled, or check skipped
#
# On the slow path an UPGRADE_AVAILABLE line may be followed by an indented
# per-copy detail line (which dir is behind), for the human to see. The first
# token of the first line is always the machine-readable verdict.
#
# This script scans EVERY installed copy of psychic-skill (not just its own
# directory) and reports UPGRADE_AVAILABLE if ANY copy is behind remote. This is
# deliberate: psychic-skill can be installed in several roots at once (~/.agents,
# ~/.claude, ~/.codex, plus project-local variants) and the host may load a
# different copy than the one that sorts first. A single copy scanned in
# isolation hid staleness before.
#
# Env overrides (for testing):
#   PSYCHIC_SKILL_DIR        — single-dir mode: scan ONLY this dir (also locates bin/)
#   PSYCHIC_SKILL_DIRS       — explicit space-separated dir list to scan
#   PSYCHIC_SKILL_REMOTE_URL — override remote VERSION URL
#   PSYCHIC_SKILL_STATE_DIR  — override ~/.psychic-skill state directory
set -euo pipefail

SELF_DIR="${PSYCHIC_SKILL_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${PSYCHIC_SKILL_STATE_DIR:-$HOME/.psychic-skill}"
CACHE_FILE="$STATE_DIR/last-update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
REMOTE_URL="${PSYCHIC_SKILL_REMOTE_URL:-https://raw.githubusercontent.com/daniel-nelson/psychic-skill/main/VERSION}"

# ─── Force flag (busts cache + snooze for standalone /psychic-update-skill) ──
FORCE_CHECK=false
if [ "${1:-}" = "--force" ]; then
  FORCE_CHECK=true
  rm -f "$CACHE_FILE" 2>/dev/null || true
  rm -f "$SNOOZE_FILE" 2>/dev/null || true
fi

# ─── Step 0: Check if updates are disabled ────────────────────
_UC=$("$SELF_DIR/bin/psychic-skill-config" get update_check 2>/dev/null || true)
if [ "$_UC" = "false" ]; then
  exit 0
fi

# ─── Install-dir enumeration ─────────────────────────────────
# Echo one absolute path per existing install copy, deduplicated by realpath.
list_install_dirs() {
  if [ -n "${PSYCHIC_SKILL_DIRS:-}" ]; then
    printf '%s\n' $PSYCHIC_SKILL_DIRS
    return
  fi
  if [ -n "${PSYCHIC_SKILL_DIR:-}" ]; then
    printf '%s\n' "$PSYCHIC_SKILL_DIR"
    return
  fi
  local candidates=(
    "${CLAUDE_SKILL_DIR:-}"
    "${CODEX_SKILL_DIR:-}"
    "$HOME/.agents/skills/psychic-skill"
    "$HOME/.claude/skills/psychic-skill"
    "$HOME/.codex/skills/psychic-skill"
    ".agents/skills/psychic-skill"
    ".claude/skills/psychic-skill"
    ".codex/skills/psychic-skill"
  )
  local seen="" d rp
  for d in "${candidates[@]}"; do
    [ -n "$d" ] || continue
    [ -d "$d" ] || continue
    rp="$(cd "$d" 2>/dev/null && pwd -P)" || continue
    case ":$seen:" in *":$rp:"*) continue ;; esac
    seen="$seen:$rp"
    printf '%s\n' "$rp"
  done
}

# ver_lt A B → return 0 (true) if version A is strictly less than B.
ver_lt() {
  [ "$1" = "$2" ] && return 1
  local IFS=. i max
  local -a A=($1) B=($2)
  max=${#A[@]}
  [ ${#B[@]} -gt "$max" ] && max=${#B[@]}
  for ((i = 0; i < max; i++)); do
    local ai="${A[i]:-0}" bi="${B[i]:-0}"
    ai="${ai%%[!0-9]*}"; bi="${bi%%[!0-9]*}"
    ai="${ai:-0}"; bi="${bi:-0}"
    if [ "$ai" -lt "$bi" ]; then return 0; fi
    if [ "$ai" -gt "$bi" ]; then return 1; fi
  done
  return 1
}

# Pretty path for humans: collapse $HOME to ~.
disp() { case "$1" in "$HOME"/*) printf '~%s' "${1#"$HOME"}" ;; *) printf '%s' "$1" ;; esac; }

# ─── Step 1: Read local versions — LOCAL is the LOWEST across all copies ──────
LOCAL=""
DIRS=()
VERS=()
while IFS= read -r dir; do
  [ -n "$dir" ] || continue
  v=""
  [ -f "$dir/VERSION" ] && v="$(tr -d '[:space:]' < "$dir/VERSION" 2>/dev/null || true)"
  [ -n "$v" ] || v="0"          # missing/unreadable VERSION → treat as behind
  DIRS+=("$dir")
  VERS+=("$v")
  if [ -z "$LOCAL" ] || ver_lt "$v" "$LOCAL"; then LOCAL="$v"; fi
done < <(list_install_dirs)

if [ -z "$LOCAL" ]; then
  exit 0  # No install copy found → skip check
fi

# build_detail <remote> — echo an indented "which copies are behind" line.
build_detail() {
  local remote="$1" i out=""
  for i in "${!DIRS[@]}"; do
    local tag=""
    ver_lt "${VERS[i]}" "$remote" && tag=" (behind)"
    out="$out · $(disp "${DIRS[i]}") ${VERS[i]}$tag"
  done
  [ -n "$out" ] && printf '  %s\n' "${out# · }"
}

# ─── Step 2: Check "just upgraded" marker ─────────────────────
if [ "$FORCE_CHECK" != "true" ] && [ -f "$MARKER_FILE" ]; then
  OLD="$(cat "$MARKER_FILE" 2>/dev/null | tr -d '[:space:]')"
  rm -f "$MARKER_FILE" 2>/dev/null || true
  rm -f "$SNOOZE_FILE" 2>/dev/null || true
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE" 2>/dev/null || true
  if [ -n "$OLD" ]; then
    echo "JUST_UPGRADED $OLD $LOCAL"
  fi
  exit 0
fi

# ─── Snooze helper ──────────────────────────────────────────
# check_snooze <remote_version>
#   Returns 0 if snoozed (should stay quiet), 1 if not snoozed (should output).
#
#   Snooze file format: <version> <level> <epoch>
#   Level durations: 1=24h, 2=48h, 3+=7d
#   New version (version mismatch) resets snooze.
check_snooze() {
  if [ "$FORCE_CHECK" = "true" ]; then
    return 1
  fi

  local remote_ver="$1"
  if [ ! -f "$SNOOZE_FILE" ]; then
    return 1  # no snooze file → not snoozed
  fi
  local snoozed_ver snoozed_level snoozed_epoch
  snoozed_ver="$(awk '{print $1}' "$SNOOZE_FILE" 2>/dev/null || true)"
  snoozed_level="$(awk '{print $2}' "$SNOOZE_FILE" 2>/dev/null || true)"
  snoozed_epoch="$(awk '{print $3}' "$SNOOZE_FILE" 2>/dev/null || true)"

  # Validate: all three fields must be non-empty
  if [ -z "$snoozed_ver" ] || [ -z "$snoozed_level" ] || [ -z "$snoozed_epoch" ]; then
    return 1  # corrupt file → not snoozed
  fi

  # Validate: level and epoch must be integers
  case "$snoozed_level" in *[!0-9]*) return 1 ;; esac
  case "$snoozed_epoch" in *[!0-9]*) return 1 ;; esac

  # New version dropped? Ignore snooze.
  if [ "$snoozed_ver" != "$remote_ver" ]; then
    return 1
  fi

  # Compute snooze duration based on level
  local duration
  case "$snoozed_level" in
    1) duration=86400 ;;   # 24 hours
    2) duration=172800 ;;  # 48 hours
    *) duration=604800 ;;  # 7 days (level 3+)
  esac

  local now
  now="$(date +%s)"
  local expires=$(( snoozed_epoch + duration ))
  if [ "$now" -lt "$expires" ]; then
    return 0  # still snoozed
  fi

  return 1  # snooze expired
}

# ─── Step 3: Check cache freshness ──────────────────────────
# UP_TO_DATE: 60 min TTL (detect new releases quickly)
# UPGRADE_AVAILABLE: 720 min TTL (keep nagging)
if [ "$FORCE_CHECK" != "true" ] && [ -f "$CACHE_FILE" ]; then
  CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
  case "$CACHED" in
    UP_TO_DATE*)        CACHE_TTL=60 ;;
    UPGRADE_AVAILABLE*) CACHE_TTL=720 ;;
    *)                  CACHE_TTL=0 ;;  # corrupt → force re-fetch
  esac

  STALE=$(find "$CACHE_FILE" -mmin +$CACHE_TTL 2>/dev/null || true)
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE*)
        CACHED_VER="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_VER" = "$LOCAL" ]; then
          exit 0
        fi
        ;;
      UPGRADE_AVAILABLE*)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_OLD" = "$LOCAL" ]; then
          CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
          if check_snooze "$CACHED_NEW"; then
            exit 0  # snoozed — stay quiet
          fi
          echo "$CACHED"
          build_detail "$CACHED_NEW"
          exit 0
        fi
        ;;
    esac
  fi
fi

# ─── Step 4: Slow path — fetch remote version ────────────────
mkdir -p "$STATE_DIR" 2>/dev/null || true

REMOTE=""
REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null || true)"
REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"

# Validate: must look like a version number (reject HTML error pages)
if ! echo "$REMOTE" | grep -qE '^[0-9]+\.[0-9.]+$'; then
  # Invalid or empty response — assume up to date
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE" 2>/dev/null || true
  exit 0
fi

# Any installed copy behind remote? (LOCAL is the lowest across all copies.)
if ! ver_lt "$LOCAL" "$REMOTE"; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE" 2>/dev/null || true
  exit 0
fi

# Some copy is behind — upgrade available.
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE" 2>/dev/null || true
if check_snooze "$REMOTE"; then
  exit 0  # snoozed — stay quiet
fi

echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
build_detail "$REMOTE"
